{
  "name": "system-monitor",
  "displayName": "System Monitor — CPU RAM GPU Disk",
  "description": "Live CPU (per-core), RAM, multi-GPU, multi-disk and network charts in the sidebar — Task Manager style. Windows, macOS, Linux, WSL.",
  "version": "1.5.0",
  "publisher": "demontego",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Demontego/system-monitor"
  },
  "bugs": {
    "url": "https://github.com/Demontego/system-monitor/issues"
  },
  "homepage": "https://github.com/Demontego/system-monitor#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "cpu",
    "ram",
    "gpu",
    "disk",
    "network",
    "system monitor",
    "task manager",
    "performance",
    "hardware",
    "status bar",
    "resources",
    "memory"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "system-monitor",
          "title": "System Monitor",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "system-monitor": [
        {
          "type": "webview",
          "id": "systemMonitor.panel",
          "name": "Charts"
        }
      ]
    },
    "commands": [
      {
        "command": "systemMonitor.toggleCpuCharts",
        "title": "System Monitor: Toggle CPU Total / Logical Charts"
      },
      {
        "command": "systemMonitor.refresh",
        "title": "System Monitor: Refresh Now"
      },
      {
        "command": "systemMonitor.openPanel",
        "title": "System Monitor: Open Charts Panel"
      },
      {
        "command": "systemMonitor.attachProcess",
        "title": "System Monitor: Attach Process"
      },
      {
        "command": "systemMonitor.detachProcess",
        "title": "System Monitor: Detach Process"
      },
      {
        "command": "systemMonitor.configureStatusBar",
        "title": "System Monitor: Configure Status Bar"
      },
      {
        "command": "systemMonitor.copyCudaDevices",
        "title": "System Monitor: Copy CUDA_VISIBLE_DEVICES (all GPUs)"
      }
    ],
    "configuration": {
      "title": "System Monitor",
      "properties": {
        "systemMonitor.intervalMs": {
          "type": "number",
          "default": 2000,
          "minimum": 500,
          "description": "Poll interval in milliseconds"
        },
        "systemMonitor.showCpu": {
          "type": "boolean",
          "default": true,
          "description": "Show CPU in the status bar"
        },
        "systemMonitor.showMem": {
          "type": "boolean",
          "default": true,
          "description": "Show memory in the status bar"
        },
        "systemMonitor.showGpu": {
          "type": "boolean",
          "default": true,
          "description": "Show GPU in the status bar"
        },
        "systemMonitor.showNetwork": {
          "type": "boolean",
          "default": true,
          "description": "Show network in the status bar"
        },
        "systemMonitor.showDisk": {
          "type": "boolean",
          "default": true,
          "description": "Show disk I/O in the status bar"
        },
        "systemMonitor.cpuCharts": {
          "type": "string",
          "enum": ["total", "logical"],
          "default": "total",
          "description": "CPU charts: overall utilization or per logical processor (Task Manager style)"
        },
        "systemMonitor.timeWindow": {
          "type": "string",
          "enum": ["1m", "5m", "30m"],
          "default": "5m",
          "description": "Chart history window: last 1 / 5 / 30 minutes"
        },
        "systemMonitor.showProcess": {
          "type": "boolean",
          "default": true,
          "description": "Show process attach control in the status bar"
        },
        "systemMonitor.autoAttachDebug": {
          "type": "boolean",
          "default": true,
          "description": "Try to auto-attach when a debug session starts"
        },
        "systemMonitor.detachOnDebugEnd": {
          "type": "boolean",
          "default": false,
          "description": "Detach process monitor when debug session ends"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish:ovsx": "ovsx publish",
    "publish:vsce": "vsce publish"
  },
  "dependencies": {
    "systeminformation": "^5.25.11"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "ovsx": "^0.10.1",
    "typescript": "^5.3.3"
  }
}
